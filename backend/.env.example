# Database
DATABASE_URL=sqlite+aiosqlite:///./parcelhub.db

# Tracking Providers
SEVENTEEN_TRACK_API_KEY=your_17track_api_key_here
TRACKING_PROVIDER=mock

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
APP_ENV=development
LOG_LEVEL=INFO

# Polling
POLLING_INTERVAL_ACTIVE_MINUTES=120
POLLING_INTERVAL_STALE_MINUTES=720
